PORT=4000

# --- Database ---
# Runtime connects as application_role (a non-superuser that RESPECTS RLS) so the
# identity_markers policy actually applies (§2.2 activation). The app reads
# APPLICATION_DATABASE_URL first and only falls back to DATABASE_URL if it is unset.
APPLICATION_DATABASE_URL=postgresql://application_role:password@localhost:5432/postgres
# postgres-role connection. BYPASSRLS — keep this for running migrations ONLY,
# never for serving requests.
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
# Disposable test branch used by the integration suite (NODE_ENV=test). When unset,
# the integration tests under tests/integration/ self-skip.
APPLICATION_DATABASE_URL_TEST=postgresql://application_role:password@localhost:5432/postgres_test

# --- Auth ---
JWT_SECRET=your_jwt_secret

# --- Anonymity engine (server/src/services/anonymity.ts) ---
ANONYMITY_MASTER_KEY=64_hex_chars_or_base64_32_byte_key
ANONYMITY_TENANT_SALT=per_tenant_salt

# --- Supabase (legacy auth/search clients) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
